# ── 필수 ────────────────────────────────────────────────────────────────
# Claude API 키 (https://console.anthropic.com/ → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 선택 ────────────────────────────────────────────────────────────────
# 서버 포트
PORT=8787

# 사용 모델. 모바일 비서는 속도·비용 균형상 Sonnet 권장. 더 똑똑하게: claude-opus-4-8
AGENT_MODEL=claude-sonnet-4-6

# 응답 최대 토큰
AGENT_MAX_TOKENS=1536

# tool-use 최대 반복 횟수(무한루프 방지)
MAX_AGENT_TURNS=6

# Claude 네이티브 웹검색 사용 여부(true/false). 켜면 별도 검색 키 불필요.
ENABLE_WEB_SEARCH=true

# (선택) 첨부된 음성 클립을 서버에서 전사하려면 Groq 키를 넣으세요.
# 온디바이스 음성검색(STT→text)은 이 키 없이도 동작합니다. hold-to-talk 오디오 파일만 해당.
# https://console.groq.com/keys  (무료 티어, whisper-large-v3)
GROQ_API_KEY=

# CORS 허용 오리진(쉼표 구분). 모바일 네이티브 앱은 CORS 무관하나, 웹 프리뷰용.
CORS_ORIGINS=*

# (강력 권장, 공개 배포 시) 접근 토큰. 설정하면 /v1/agent 호출에 x-access-token 헤더가
# 일치해야 한다. 공개 Vercel URL 에서 누군가 당신의 Claude 비용을 소진하는 것을 막는다.
# 임의의 긴 문자열로 지정하세요. 예) openssl rand -hex 16
AGENT_ACCESS_TOKEN=
